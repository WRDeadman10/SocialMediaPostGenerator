# Firebase Cloud Functions base URL
# Local emulator (replace YOUR_PROJECT_ID):
VITE_FUNCTIONS_URL=http://127.0.0.1:5001/YOUR_PROJECT_ID/us-central1
# Production (replace YOUR_REGION and YOUR_PROJECT_ID):
# VITE_FUNCTIONS_URL=https://YOUR_REGION-YOUR_PROJECT_ID.cloudfunctions.net

# Firebase Hosting production builds should usually NOT set VITE_FUNCTIONS_URL (use Hosting rewrites).
# Only set this if you intentionally want cross-origin calls (not recommended):
# VITE_FORCE_CROSS_ORIGIN_FUNCTIONS_URL=1
