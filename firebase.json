{
  "hosting": {
    "public": "dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      { "source": "/getProjects", "function": "getProjects" },
      { "source": "/createProject", "function": "createProject" },
      { "source": "/saveProject", "function": "saveProject" },
      { "source": "/deleteProject", "function": "deleteProject" },
      { "source": "/uploadAsset", "function": "uploadAsset" },
      { "source": "**", "destination": "/index.html" }
    ]
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs20"
  }
}
