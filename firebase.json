{
  "hosting": {
    "public": "dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      { "source": "/getProjects", "function": { "functionId": "getProjects", "region": "us-central1" } },
      { "source": "/createProject", "function": { "functionId": "createProject", "region": "us-central1" } },
      { "source": "/saveProject", "function": { "functionId": "saveProject", "region": "us-central1" } },
      { "source": "/deleteProject", "function": { "functionId": "deleteProject", "region": "us-central1" } },
      { "source": "/uploadAsset", "function": { "functionId": "uploadAsset", "region": "us-central1" } },
      { "source": "**", "destination": "/index.html" }
    ]
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs20"
  }
}
