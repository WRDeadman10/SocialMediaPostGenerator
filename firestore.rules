rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /projects/{projectId} {
      allow read, write: if true; // TODO: add Firebase Auth rules before going public
    }
    match /assetLibrary/{assetId} {
      allow read, write: if true; // TODO: add Firebase Auth rules before going public
    }
    match /settings/{docId} {
      allow read, write: if true; // TODO: add Firebase Auth rules before going public
    }
  }
}
